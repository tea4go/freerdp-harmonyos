# ===========================================
# FreeRDP HarmonyOS - Git Ignore Rules
# ===========================================

# -------------------------------------------
# Build Outputs
# -------------------------------------------
build/
*.hap
*.app
*.so.debug
*.so.dSYM/

# -------------------------------------------
# IDE & Editor
# -------------------------------------------
.idea/
*.iml
.vscode/
*.swp
*.swo
*~

# -------------------------------------------
# Operating System Files
# -------------------------------------------
.DS_Store
._*
Thumbs.db
desktop.ini

# -------------------------------------------
# Dependencies
# -------------------------------------------
node_modules/
oh_modules/
oh_modules.bak/

# -------------------------------------------
# Logs & Temporary Files
# -------------------------------------------
*.log
*.tmp
*.temp
.cache/
*.cache

# -------------------------------------------
# DevEco Studio
# -------------------------------------------
.preview/
.cxx/
.hvigor/
local.properties

# -------------------------------------------
# Signing Files (SENSITIVE - Never commit!)
# -------------------------------------------
.signing/*.p12
.signing/*.cer
.signing/*.p7b
.signing/*.jks
.signing/*.keystore
*.p12
*.cer
*.p7b
*.jks
*.keystore

# Keep only documentation in signing directory
!.signing/README.md
!.signing/签名文件说明.txt

# -------------------------------------------
# Scripts - Temporary & Personal
# -------------------------------------------
# Test scripts
test-*.ps1
test-*.cmd
test-*.sh

# Temporary scripts
temp-*.ps1
temp-*.cmd
temp-*.sh

# Debug/Development scripts
debug-*.ps1
debug-*.cmd
debug-*.sh

# Local/Personal scripts
local-*.ps1
local-*.cmd
local-*.sh
*-local.ps1
*-local.cmd
*-local.sh

# Experimental/Work-in-progress scripts
experimental-*.ps1
experimental-*.cmd
experimental-*.sh
wip-*.ps1
wip-*.cmd
wip-*.sh

# Backup and old scripts
*.backup.ps1
*.backup.cmd
*.backup.sh
*.old.ps1
*.old.cmd
*.old.sh

# Private/Sensitive scripts
*-private.ps1
*-private.cmd
*-private.sh
*.secret.ps1
*.secret.cmd
*.secret.sh

# -------------------------------------------
# Native Build Artifacts
# -------------------------------------------
native-build/
native-install/
native-src/

# -------------------------------------------
# Legacy Android (if any)
# -------------------------------------------
android/Studio/build/
android/Studio/freeRDPCore/build/
android/Studio/aFreeRDP/build/
android/Studio/*.apk
android/Studio/local.properties

# -------------------------------------------
# Claude AI & Chat Logs (SENSITIVE)
# -------------------------------------------
聊天记录/
.claude/settings.json
.claude/projects/*/memory/
grep
.claude/settings.local.json
.hvigor/cache/file-cache.json
.hvigor/cache/meta.json
.hvigor/cache/task-cache.json
.hvigor/dependencyMap/dependencyMap.json5
.hvigor/outputs/logs/details/details.json
.hvigor/outputs/sync/fileCache.json
.hvigor/outputs/sync/output.json
.hvigor/report/report-202601181724003310.json
.hvigor/report/report-202601181732081580.json
